<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="helvety.screenshots.Views.SaveLocationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Border
            Padding="16"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="12">
            <StackPanel Spacing="12">
                <TextBlock FontSize="24" FontWeight="SemiBold" Text="Save Location" />
                <TextBlock
                    x:Name="SaveFolderText"
                    Text="Save Folder: (loading...)"
                    TextWrapping="WrapWholeWords" />
                <Button
                    x:Name="ChooseSaveFolderButton"
                    HorizontalAlignment="Left"
                    Click="ChooseSaveFolderButton_Click"
                    Content="Choose Folder" />
                <TextBlock
                    x:Name="SaveFolderStatusText"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text=""
                    TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
