<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="helvety.screenshots.Views.KeyBindingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Padding="16"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="12">
            <StackPanel Spacing="10">
                <TextBlock FontSize="24" FontWeight="SemiBold" Text="Key-Bindings" />
                <TextBlock
                    x:Name="CurrentBindingText"
                    Text="Current Binding: Shift+S"
                    TextWrapping="WrapWholeWords" />
                <Button
                    x:Name="StartCaptureButton"
                    HorizontalAlignment="Left"
                    Click="StartCaptureButton_Click"
                    Content="Set Hotkey" />
                <TextBlock
                    x:Name="CaptureInstructionText"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Set a shortcut with at least one modifier."
                    TextWrapping="WrapWholeWords" />
                <TextBlock
                    x:Name="CapturePreviewText"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Capture preview: (not listening)"
                    TextWrapping="WrapWholeWords" />
                <TextBlock
                    x:Name="BindingStatusText"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text=""
                    TextWrapping="WrapWholeWords" />
            </StackPanel>
        </Border>

        <Border
            Grid.Row="2"
            Padding="16"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="12">
            <StackPanel Spacing="8">
                <TextBlock FontSize="18" FontWeight="SemiBold" Text="Hotkey Press Messages" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="Recent shortcut triggers."
                    TextWrapping="WrapWholeWords" />
                <ListView
                    x:Name="MessageListView"
                    Height="300"
                    IsItemClickEnabled="False"
                    SelectionMode="None" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
